{
  "type": "module",
  "name": "minttw",
  "version": "1.0.3",
  "description": "A simple and painless custom TurboWarp extension development platform, powered by bundling.",
  "main": "build/extension.js",
  "scripts": {
    "build": "node scripts/build.js",
    "build:prod": "node scripts/build.js --production",
    "build:recommended": "node scripts/build.js",
    "watch": "node scripts/build.js --watch",
    "watch:notify": "node scripts/build.js --watch --notify",
    "serve": "node scripts/serve.js",
    "init": "node scripts/init.js",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/",
    "format": "prettier --write src/",
    "validate": "node scripts/validate.js",
    "validate:assets": "node scripts/validate-assets.js",
    "asset:list": "node scripts/asset.js list",
    "asset:add": "node scripts/asset.js add",
    "asset:remove": "node scripts/asset.js remove",
    "test": "node scripts/test.js",
    "test:watch": "node scripts/test.js --watch",
    "fullstack": "npm run format && npm run lint && npm run validate && npm run build && npm run test"
  },
  "keywords": [
    "turbowarp",
    "scratch",
    "extension"
  ],
  "author": "",
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "chokidar": "^5.0.0",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "prettier": "^3.0.0",
    "terser": "^5.46.1"
  }
}
